<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ToDoApplication.Views.MainWindow"
        Title="ToDo Application" Width="400" Height="450"
        WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">

        <TextBlock Text="MAIN MENU" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" Margin="0, 0, 0, 10"/>

        <Button Content="Add task" Width="200" HorizontalContentAlignment="Center"></Button>
        <Button Content="Show current tasks" Width="200" HorizontalContentAlignment="Center"></Button>
        <Button Content="Add property to task" Width="200" HorizontalContentAlignment="Center"></Button>
        <Button Content="Mark a task done" Width="200" HorizontalContentAlignment="Center"></Button>
        <Button Content="Show finished tasks" Width="200" HorizontalContentAlignment="Center"></Button>
        <Button Content="Edit a task" Width="200" HorizontalContentAlignment="Center"></Button>
        <Button Content="Quit" Width="200" HorizontalContentAlignment="Center"></Button>

    </StackPanel>
    
</Window>