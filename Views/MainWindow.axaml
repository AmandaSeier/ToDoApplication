<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ToDoApplication.Views.MainWindow"
        Title="ToDo Application"
        Width="300"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{StaticResource WhiteColor}" Offset="0.0"/>
            <GradientStop Color="{StaticResource AquaColor}" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>

        <Border Background="Black"
                Opacity="0.25"
                Width="150"
                Height="75"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="0,0,36,0"/>

        <Border Background="{StaticResource DarkBlue}"
                Width="145"
                Height="70"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="0,0,35,0"/>

        <TextBlock Text="Tasks"
                   FontFamily="{StaticResource VietnamPro}"
                   FontSize="36"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource RedColor}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="20,10,0,0">
        </TextBlock>

        <TextBlock Text="Tasks"
                   FontFamily="{StaticResource VietnamPro}"
                   FontSize="36"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource FlamingoBrush}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="18,8,0,0">
        </TextBlock>

        <Border Background="{StaticResource DarkBlue}"
                Width="260"
                Height="515"
                Opacity="0.25"
                CornerRadius="15,15,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"/>

        <Border Width="109"
                Height="57"
                Background="{StaticResource DarkBlue}"
                CornerRadius="40"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="30,0,0,25">

            <Grid ColumnDefinitions="Auto,Auto"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <Border Grid.Column="0"
                        Width="38"
                        Height="38"
                        CornerRadius="20"
                        Background="{StaticResource WhiteBrush}">
                    <Button Background="Transparent"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="FinishedTasksWindow">
                        <Svg Path="avares://ToDoApplication/Assets/Icons/HistoryIcon.svg"
                             Width="26"
                             Height="26"/>
                    </Button>
                </Border>

                <Border Grid.Column="1"
                        Width="38"
                        Height="38"
                        CornerRadius="20"
                        Background="{StaticResource WhiteBrush}"
                        Margin="10,0,0,0">
                    <Button Background="Transparent"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="AddTaskWindow">
                        <Svg Path="avares://ToDoApplication/Assets/Icons/PlusIcon.svg"
                             Width="26"
                             Height="26"/>
                    </Button>
                </Border>

            </Grid>
        </Border>

        <Border Width="55"
                Height="57"
                Background="{StaticResource DarkBlue}"
                CornerRadius="40"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,30,25">

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <Button x:Name="MenuButton"
                        Background="Transparent"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="MenuButtonOpen">
                    <Svg Path="avares://ToDoApplication/Assets/Icons/MenuIcon.svg"
                         Width="30"
                         Height="30"/>
                </Button>

            </Grid>
        </Border>

        <Popup x:Name="PopupMenu"
               Placement="Bottom"
               PlacementTarget="{Binding #MenuButton}"
               IsOpen="False"
               IsLightDismissEnabled="True">

            <Grid Width="55"
                  Height="150"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom">

                <Border Background="Black"
                        Opacity="0.25"
                        CornerRadius="30"
                        Margin="0,0,0,0"
                        Grid.Row="0"/>

                <StackPanel Grid.Row="0"
                            Spacing="12"
                            Margin="0,25,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">

                    <Border Width="38"
                            Height="38"
                            CornerRadius="20"
                            Background="{StaticResource DarkBlue}"
                            ZIndex="10">
                        <Button Background="Transparent"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <Svg Path="avares://ToDoApplication/Assets/Icons/EditIcon.svg"
                                 Width="26"
                                 Height="26"/>
                        </Button>
                    </Border>

                    <Border Width="38"
                            Height="38"
                            CornerRadius="20"
                            Background="{StaticResource DarkBlue}"
                            ZIndex="10">
                        <Button Background="Transparent"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <Svg Path="avares://ToDoApplication/Assets/Icons/SettingsIcon.svg"
                                 Width="26"
                                 Height="26"/>
                        </Button>
                    </Border>

                    <Border Width="38"
                            Height="38"
                            CornerRadius="20"
                            Background="{StaticResource DarkBlue}"
                            ZIndex="10">
                        <Button Background="Transparent"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <Svg Path="avares://ToDoApplication/Assets/Icons/AccountIcon.svg"
                                 Width="26"
                                 Height="26"/>
                        </Button>
                    </Border>

                </StackPanel>

            </Grid>

        </Popup>

    </Grid>
</Window>
