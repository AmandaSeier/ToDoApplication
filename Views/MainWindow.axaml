<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ToDoApplication.Views.MainWindow"
        Title="ToDo Application" Width="1179" Height="2556"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{Binding Source={StaticResource White}, Path=Color}" Offset="0.0"/>
            <GradientStop Color="{Binding Source={StaticResource Flamingo}, Path=Color}" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Border Width="1000" Height="300" 
            Background="#40000000" 
            CornerRadius="150" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Bottom" 
            Margin="0,0,0,80">
            
            <Grid ColumnDefinitions="*,*,*">
                
                <Border Grid.Column="0" 
                    Width="200" Height="200" 
                    CornerRadius="100" 
                    Background="{StaticResource DarkBlue}"
                    BoxShadow="15 15 0 0 #80000000"
                    HorizontalAlignment="Center" 
                    Margin="0,0,-100,0"
                    VerticalAlignment="Center">

                    <Svg Path="avares://ToDoApplication/Assets/Icons/MenuIcon.svg"
                        Width="120" Height="120"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>

                <Border Grid.Column="1" 
                    Width="200" Height="200" 
                    CornerRadius="100" 
                    Background="{StaticResource Blue}" 
                    BoxShadow="15 15 0 0 #80000000"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">

                    <Svg Path="avares://ToDoApplication/Assets/Icons/PlusIcon.svg"
                        Width="160" Height="160"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                    
                <Border Grid.Column="2" 
                    Width="200" Height="200" 
                    CornerRadius="100" 
                    Background="{StaticResource Blue}"
                    BoxShadow="15 15 0 0 #80000000"
                    Margin="0,0,100,0" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">

                    <Svg Path="avares://ToDoApplication/Assets/Icons/HistoryIcon.svg"
                        Width="125" Height="125"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>    
            </Grid>
        </Border>
    </Grid>
</Window>