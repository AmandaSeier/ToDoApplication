<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ToDoApplication.Views.FinishedTasksWindow"
        Title="Finished Tasks" Width="1179" Height="2556"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="{Binding Source={StaticResource Aqua}, Path=Color}" Offset="0.0"/>
            <GradientStop Color="{Binding Source={StaticResource White}, Path=Color}" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">

    </StackPanel>
    
</Window>